{
  "name": "pdf-annotated",
  "displayName": "PDF Annotated",
  "description": "A fast PDF previewer and annotation editor for VS Code powered by PDFium WebAssembly.",
  "publisher": "jenul-ferdinand",
  "icon": "icon.png",
  "author": {
    "name": "jenul-ferdinand"
  },
  "homepage": "https://github.com/jenul-ferdinand/PDF-Annotated",
  "license": "MIT",
  "categories": [
    "Visualization",
    "Programming Languages"
  ],
  "repository": {
    "url": "https://github.com/jenul-ferdinand/PDF-Annotated"
  },
  "version": "0.1.0",
  "browser": "./dist/extension.browser.js",
  "main": "./dist/extension.node.js",
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "capabilities": {
    "virtualWorkspaces": true,
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "contributes": {
    "customEditors": [
      {
        "viewType": "pdfAnnotated.PDFEdit",
        "displayName": "PDF Annotated",
        "selector": [
          {
            "filenamePattern": "*.pdf"
          }
        ],
        "priority": "default"
      }
    ],
    "configuration": {
      "title": "PDF Annotated",
      "properties": {
        "pdfAnnotated.defaultZoomLevel": {
          "type": "string",
          "default": "page-width",
          "enum": [
            "page-width",
            "page-fit",
            "page-height",
            "auto",
            "50%",
            "75%",
            "100%",
            "125%",
            "150%",
            "200%",
            "300%",
            "400%"
          ],
          "description": "The initial zoom level when opening a PDF file."
        },
        "pdfAnnotated.defaultSpreadMode": {
          "type": "string",
          "default": "odd",
          "enum": [
            "none",
            "odd",
            "even"
          ],
          "description": "The initial spread mode when opening a PDF file."
        },
        "pdfAnnotated.tabBar": {
          "type": "string",
          "default": "never",
          "enum": [
            "always",
            "multiple",
            "never"
          ],
          "description": "Control the visibility of the internal tab bar."
        }
      }
    }
  },
  "commands": [
    {
      "command": "pdfAnnotated.forceSave",
      "title": "Save PDF",
      "category": "PDF Annotated"
    }
  ],
  "keybindings": [
    {
      "command": "pdfAnnotated.forceSave",
      "key": "ctrl+s",
      "mac": "cmd+s",
      "when": "activeCustomEditorId == 'pdfAnnotated.PDFEdit'"
    },
    {
      "command": "workbench.action.closeActiveEditor",
      "key": "ctrl+w",
      "mac": "cmd+w",
      "when": "activeCustomEditorId == 'pdfAnnotated.PDFEdit'"
    }
  ],
  "scripts": {
    "build": "webpack",
    "package": "sh scripts/package.sh",
    "deploy": "sh scripts/publish.sh",
    "test": "bun run test:integration",
    "test:integration": "bun run build && node ./test/run-integration.js",
    "test-web": "vscode-test-web --extensionDevelopmentPath=. .",
    "test-web-headless": "vscode-test-web --extensionDevelopmentPath=. --headless ."
  },
  "devDependencies": {
    "@actions/core": "^3.0.0",
    "@embedpdf/svelte-pdf-viewer": "^2.13.0",
    "@types/vscode": "^1.75.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/test-web": "^0.0.80",
    "@vscode/vsce": "^3.7.1",
    "css-loader": "^7.1.4",
    "ovsx": "^0.10.10",
    "style-loader": "^4.0.0",
    "svelte": "^5.55.0",
    "svelte-loader": "^3.2.4",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "@embedpdf/core": "^2.13.0",
    "@embedpdf/plugin-document-manager": "^2.13.0",
    "@embedpdf/plugin-render": "^2.13.0"
  }
}
